exports[`help/usage golden snapshots > matches the query help snapshot > query 1`] = `
"Usage: wikigr query [options] <pack> <question>

Query a knowledge pack and print ranked retrieval results as JSON.

Arguments:
  pack           pack directory name
  question       natural-language question

Options:
  -k, --k <n>    number of results to retrieve (default: 5)
  --mode <mode>  retrieval strategy (choices: "vector", "hybrid", "lexical",
                 default: "vector")
  -h, --help     display help for command
"
`;

exports[`help/usage golden snapshots > matches the root help snapshot > root 1`] = `
"Usage: wikigr [options] [command]

Knowledge-pack command-line interface (query, ingestion, and pack management).

Options:
  -V, --version                      output the version number
  --packs-dir <dir>                  directory containing installed packs
  -h, --help                         display help for command

Commands:
  query [options] <pack> <question>  Query a knowledge pack and print ranked
                                     retrieval results as JSON.
  status                             Report the resolved packs directory and
                                     the installed packs.
  create [options]                   Build a new pack database from seed URLs
                                     or a config file.
  update [options]                   Resume / extend an existing pack's graph
                                     from new seeds.
  research-sources [options]         Discover candidate source URLs reachable
                                     from the seeds (fetch-only).
  pack                               Manage installed knowledge packs.
  help [command]                     display help for command
"
`;

exports[`help/usage golden snapshots > matches the status help snapshot > status 1`] = `
"Usage: wikigr status [options]

Report the resolved packs directory and the installed packs.

Options:
  -h, --help  display help for command
"
`;
