{
  "name": "agent-kgpacks-ts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TypeScript port of agent-kgpacks — a LadybugDB-backed knowledge-pack platform.",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.0",
  "bin": {
    "wikigr": "dist/wikigr.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:root": "vitest run",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:no-python": "node scripts/check-no-python.mjs",
    "catalog:list": "node scripts/build-catalog.mjs --list",
    "catalog:build": "node scripts/build-catalog.mjs",
    "catalog:eval": "node scripts/eval-catalog.mjs",
    "cve:build": "node scripts/build-cve-pack.mjs",
    "bundle:cli": "node scripts/bundle-cli.mjs",
    "prepare": "node scripts/bundle-cli.mjs"
  },
  "dependencies": {
    "@github/copilot-sdk": "1.0.3",
    "@huggingface/transformers": "^3.8.1",
    "@ladybugdb/core": "0.17.1",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^3.2.6",
    "esbuild": "^0.28.1",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^3.2.6"
  },
  "pnpm": {
    "overrides": {
      "vite": "^6.4.3"
    }
  }
}
