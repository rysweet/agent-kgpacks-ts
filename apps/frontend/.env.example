# @kgpacks/frontend — build-time configuration (committed example).
#
# All VITE_* values are inlined into the PUBLIC bundle. Never put secrets here;
# LLM/provider credentials live exclusively on the backend.

# Base URL prepended to every API path.
#   ''                       -> same-origin (dev proxy or co-hosted bundle)
#   https://api.example.com  -> cross-origin production API
VITE_API_BASE_URL=
