# pnpm settings for reproducible, secure installs.

# Block lifecycle (install/postinstall) scripts by default, then allow only the
# packages that legitimately need one. @ladybugdb/core's install step selects and
# links the prebuilt native binary for the current platform (it does not compile
# from source).
onlyBuiltDependencies[]=@ladybugdb/core

# Fail installs in CI if the lockfile is out of date.
# (CI also passes --frozen-lockfile explicitly.)
auto-install-peers=true
